# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# csv watcher state
/.csv_watch_state.json
/inbox/*.csv
/archive/*.csv

# local-first lifecycle store (mutable copy of the JSON snapshot)
/data/lifecycles.json

# raw source data (kept local; regenerate or pull from your own source of truth)
/MTBF Tracker_cursor.xlsx
/vantagepoint_sensor.csv

# python
__pycache__/
*.pyc
